#!/bin/bash
# lace-into -- Connect to a lace devcontainer via tmux.
#
# Usage:
#   lace-into                    Interactive picker (fzf or bash select)
#   lace-into <project>          Connect to named project
#   lace-into --pane <project>   Connect current tmux pane to named project
#   lace-into --pane             Interactive picker, connect current pane
#   lace-into --start <project>  Start a stopped container, then connect
#   lace-into --start            Pick from stopped containers to start
#   lace-into --list             List running project names
#   lace-into --status           Show running projects with ports and paths
#   lace-into --dry-run <proj>   Print the tmux commands without executing
#   lace-into --help             Show this help
#
# Prerequisites: tmux, podman/docker, lace-discover on PATH or at known location

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lace-lib.sh
. "$SCRIPT_DIR/lace-lib.sh"

err() { echo "${SCRIPT_NAME}: error: $*" >&2; }
info() { echo "${SCRIPT_NAME}: $*" >&2; }

# --- Locate lace-discover ---
LACE_DISCOVER=""
if command -v lace-discover &>/dev/null; then
  LACE_DISCOVER="lace-discover"
else
  # Check known locations
  for candidate in \
    "$SCRIPT_DIR/lace-discover" \
    "$HOME/code/weft/lace/main/bin/lace-discover" \
    "/var/home/$(whoami)/code/weft/lace/main/bin/lace-discover"; do
    if [[ -x "$candidate" ]]; then
      LACE_DISCOVER="$candidate"
      break
    fi
  done
fi

if [[ -z "$LACE_DISCOVER" ]]; then
  err "lace-discover not found on PATH or at known locations"
  err "Install it or symlink to ~/.local/bin/"
  exit 1
fi

# --- Locate lace CLI ---
# Used by --start to run `lace up --workspace-folder <path>`.
# Check co-located path first (bin/lace-into -> packages/lace/bin/lace),
# then known locations, then PATH.
#
# Validates that the runtime interpreter (node) is available on PATH.
# The lace CLI is a node script (#!/usr/bin/env node), so finding the
# binary isn't enough — node must also be reachable.
locate_lace_cli() {
  local candidate
  for candidate in \
    "$SCRIPT_DIR/../packages/lace/bin/lace" \
    "$HOME/code/weft/lace/main/packages/lace/bin/lace" \
    "/var/home/$(whoami)/code/weft/lace/main/packages/lace/bin/lace"; do
    if [[ -x "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  # Fall back to PATH
  local path_lace
  path_lace="$(command -v lace 2>/dev/null || true)"
  if [[ -n "$path_lace" ]]; then
    echo "$path_lace"
    return 0
  fi
  return 1
}

# Verify that the lace CLI's runtime interpreter is available.
# The lace CLI uses #!/usr/bin/env node — if node isn't on PATH,
# execution fails with exit 127 and an opaque "No such file" error.
verify_lace_cli() {
  local lace_cli="$1"

  # Resolve symlinks to get the actual file and check its shebang
  local resolved
  resolved="$(readlink -f "$lace_cli" 2>/dev/null || echo "$lace_cli")"

  local shebang
  shebang="$(head -c 256 "$resolved" 2>/dev/null | head -1)"

  if [[ "$shebang" == "#!/usr/bin/env node"* ]] || [[ "$shebang" == "#!/usr/bin/node"* ]]; then
    if ! command -v node &>/dev/null; then
      err "lace CLI requires node, but node is not on PATH"
      err "found lace at: $lace_cli"
      err ""
      err "node is typically installed via linuxbrew:"
      err "  /home/linuxbrew/.linuxbrew/bin/node"
      err ""
      err "ensure your shell's PATH includes linuxbrew:"
      err "  export PATH=\"/home/linuxbrew/.linuxbrew/bin:\$PATH\""
      return 1
    fi
  fi
  return 0
}

# --- Discovery helper ---
discover() {
  "$LACE_DISCOVER" "$@"
}

# --- Stopped container discovery ---
# Query container runtime for stopped devcontainers with the devcontainer.local_folder label.
# Output format: name\tworkspace_path per line
discover_stopped() {
  "$RUNTIME" ps -a \
    --filter "label=devcontainer.local_folder" \
    --filter "status=exited" \
    --format '{{.Label "devcontainer.local_folder"}}\t{{.Label "lace.project_name"}}' 2>/dev/null \
  | while IFS=$'\t' read -r local_folder project_name; do
    [[ -z "$local_folder" ]] && continue
    local name
    name="${project_name:-$(basename "$local_folder")}"
    printf '%s\t%s\n' "$name" "$local_folder"
  done
}

# --- Start a stopped container and connect ---
# Runs `lace up --workspace-folder <path>`, then re-discovers and connects.
start_and_connect() {
  local project="$1"
  local workspace_path="$2"

  local lace_cli
  lace_cli="$(locate_lace_cli)" || {
    err "lace CLI not found"
    err "Expected at: $SCRIPT_DIR/../packages/lace/bin/lace"
    err "Or install lace on PATH"
    exit 1
  }

  # Verify the runtime interpreter is available before attempting to run lace.
  # This catches the common case of node not being on PATH and gives a clear
  # diagnostic instead of a confusing "No such file or directory" + 20s of retries.
  verify_lace_cli "$lace_cli" || exit 1

  local rebuild_flag=""
  if [[ "$REBUILD" == "true" ]]; then
    rebuild_flag=" --rebuild"
  fi
  info "starting $project via lace up --workspace-folder $workspace_path$rebuild_flag ..."

  if [[ "$DRY_RUN" == "true" ]]; then
    local dry_args="lace up --workspace-folder $workspace_path"
    if [[ "$REBUILD" == "true" ]]; then
      dry_args+=" --rebuild"
    fi
    echo "$dry_args"
    echo "# then: tmux new-session -d -s $project $RUNTIME exec -it --user <user> --workdir <ws> <container> /bin/bash -l"
    echo "# then: tmux set-option -t $project @lace_container <container_name>"
    exit 0
  fi

  # Run lace up, streaming output to the user in real time via tee.
  #
  # Note: lace up may exit non-zero even when the container starts successfully,
  # e.g. if postStartCommand fails (CWD mismatch, transient error). In that case
  # the container is running but lace up reports failure. We log the warning and
  # proceed to discovery -- if the container is actually running and discoverable,
  # we connect anyway.
  #
  # The tee-based pattern shows lace up output as it happens (to stderr) while
  # capturing it for heuristic checks. With set -euo pipefail (line 16), the
  # pipeline exit status reflects lace's exit code (tee almost never fails).
  local up_logfile
  up_logfile=$(mktemp /tmp/lace-up-XXXXXX.log) || {
    err "cannot create temp file for lace up log"
    exit 1
  }
  trap "rm -f '$up_logfile'" EXIT

  local up_exit=0

  local lace_args=("up" "--workspace-folder" "$workspace_path")
  if [[ "$REBUILD" == "true" ]]; then
    lace_args+=("--rebuild")
  fi

  "${lace_cli}" "${lace_args[@]}" 2>&1 \
    | tee "$up_logfile" >&2 \
    || up_exit=$?

  local up_output
  up_output=$(cat "$up_logfile" 2>/dev/null || true)
  rm -f "$up_logfile"
  trap - EXIT

  if [[ $up_exit -eq 127 ]]; then
    # Exit 127 = command/interpreter not found. The container definitely did not start.
    err "lace CLI failed to execute (exit 127: command not found)"
    err "this usually means the node runtime is not on PATH"
    err ""
    err "lace CLI: $lace_cli"
    if [[ -n "$up_output" ]]; then
      err "output: $up_output"
    fi
    exit 1
  elif [[ $up_exit -eq 126 ]]; then
    # Exit 126 = permission denied or not executable
    err "lace CLI is not executable (exit 126: permission denied)"
    err "lace CLI: $lace_cli"
    exit 1
  elif [[ $up_exit -ne 0 ]]; then
    # Non-zero but not 126/127: lace ran but reported failure.
    # Parse structured LACE_RESULT line if available (Phase 2), falling back
    # to the "Starting devcontainer" text heuristic for older lace versions.
    local lace_result_line container_may_be_running failed_phase
    lace_result_line=$(grep '^LACE_RESULT: ' <<< "$up_output" | tail -1 || true)

    if [[ -n "$lace_result_line" ]]; then
      # Structured result available -- use it.
      local result_json="${lace_result_line#LACE_RESULT: }"

      # Extract containerMayBeRunning via glob match (no jq dependency).
      container_may_be_running="false"
      if [[ "$result_json" == *'"containerMayBeRunning":true'* ]]; then
        container_may_be_running="true"
      fi

      # Extract failedPhase via bash parameter expansion.
      local phase_fragment="${result_json#*\"failedPhase\":\"}"
      if [[ "$phase_fragment" != "$result_json" ]]; then
        failed_phase="${phase_fragment%%\"*}"
      else
        failed_phase="unknown"
      fi

      if [[ "$container_may_be_running" != "true" ]]; then
        err "lace up failed in phase '$failed_phase' (exit $up_exit)"
        err "container is not running -- no point retrying discovery"
        err ""
        err "error context (last 10 lines):"
        echo "$up_output" | grep -v '^LACE_RESULT: ' | tail -10 >&2
        err ""
        err "to debug, run lace up directly:"
        err "  lace up --workspace-folder \"$workspace_path\""
        exit 1
      fi

      info "warning: lace up failed in phase '$failed_phase' (exit $up_exit) but container may be running"
      info "checking if container is discoverable..."
    else
      # Fallback: legacy heuristic for older lace versions without LACE_RESULT.
      if ! grep -q "Starting devcontainer" <<< "$up_output"; then
        err "lace up failed before starting container (exit $up_exit)"
        err ""
        err "error context (last 10 lines):"
        echo "$up_output" | grep -v '^LACE_RESULT: ' | tail -10 >&2
        err ""
        err "to debug, run lace up directly:"
        err "  lace up --workspace-folder \"$workspace_path\""
        exit 1
      fi
      info "warning: lace up exited with code $up_exit (checking if container started anyway...)"
    fi
    # Show error context excerpt for the paths that proceed to the retry loop:
    # - Structured: container may be running (didn't exit above)
    # - Legacy: "Starting devcontainer" found (didn't exit above)
    info ""
    info "lace up error context (last 5 lines):"
    echo "$up_output" | grep -v '^LACE_RESULT: ' | tail -5 >&2
    info ""
  else
    info "container started successfully"
  fi

  # Re-discover to get the container name
  local container_name=""
  local container_workspace=""
  local attempts=0
  local max_attempts=5

  while [[ $attempts -lt $max_attempts ]]; do
    while IFS=: read -r name cname user path ws; do
      if [[ "$name" == "$project" ]]; then
        container_name="$cname"
        container_workspace="$ws"
        break
      fi
    done < <(discover)

    if [[ -n "$container_name" ]]; then
      break
    fi

    # Check if a container is even running for this workspace.
    # No running container means retries are futile.
    local container_id
    container_id=$("$RUNTIME" ps \
      --filter "label=devcontainer.local_folder=$workspace_path" \
      --format '{{.ID}}' 2>/dev/null || true)
    if [[ -z "$container_id" ]]; then
      info "no container running for $workspace_path -- aborting discovery retries"
      break
    fi

    attempts=$((attempts + 1))
    if [[ $attempts -lt $max_attempts ]]; then
      info "waiting for container to be discoverable (attempt $((attempts))/$max_attempts)..."
      sleep 2
    fi
  done

  if [[ -z "$container_name" ]]; then
    if [[ $up_exit -ne 0 ]]; then
      err "lace up failed (exit $up_exit) and container is not discoverable"
      err ""
      err "error context (last 10 lines):"
      echo "$up_output" | grep -v '^LACE_RESULT: ' | tail -10 >&2
      err ""
      err "to debug, run lace up directly:"
      err "  lace up --workspace-folder \"$workspace_path\""
      err ""
      err "common causes:"
      err "  - Container runtime not running       (check: $RUNTIME info)"
      err "  - Missing host-side files             (check validation errors above)"
      err "  - Image build failure                 (check build output above)"
      err "  - Lifecycle hook failure, no container (check: $RUNTIME ps -a --filter label=devcontainer.local_folder=\"$workspace_path\")"
    else
      err "container started but not discoverable after $max_attempts attempts"
      err ""
      err "check container status:"
      err "  $RUNTIME ps --filter label=devcontainer.local_folder=\"$workspace_path\""
      err ""
      err "to retry connection:"
      err "  lace-into $project"
    fi
    exit 1
  fi

  # If lace up failed but the container IS discoverable, just note it briefly.
  # The stack trace is noise -- the container is running and we can connect.
  if [[ $up_exit -ne 0 ]]; then
    info "container is running despite lace up exit $up_exit (likely a lifecycle hook failure)"
  fi

  if [[ "$PANE_MODE" == "true" ]]; then
    do_connect_pane "$project" "$container_name" "$container_workspace"
  else
    do_connect "$project" "$container_name" "$container_workspace"
  fi
}

# --- Argument parsing ---
PROJECT=""
ACTION=""
DRY_RUN=false
START=false
REBUILD=false
PANE_MODE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --pane)
      PANE_MODE=true
      shift
      ;;
    --start)
      START=true
      shift
      ;;
    --rebuild)
      REBUILD=true
      shift
      ;;
    --list)
      ACTION="list"
      shift
      ;;
    --status)
      ACTION="status"
      shift
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      ACTION="help"
      shift
      ;;
    -*)
      err "unknown option: $1"
      echo "Usage: lace-into [PROJECT] [--pane] [--start] [--list] [--status] [--dry-run] [--help]" >&2
      exit 1
      ;;
    *)
      PROJECT="$1"
      shift
      ;;
  esac
done

# Validate flag combinations
if [[ "$REBUILD" == "true" && "$START" != "true" ]]; then
  info "warning: --rebuild has no effect without --start (ignored)"
fi

# --pane requires running inside tmux
if [[ "$PANE_MODE" == "true" && -z "${TMUX:-}" ]]; then
  err "--pane requires running inside tmux"
  exit 1
fi

# --- Resolve user for a container ---
# Queries lace-discover for the user associated with a container name.
# Falls back to "node" if not found.
resolve_user_for_container() {
  local container_name="$1"
  while IFS=: read -r _name cname user _path _ws; do
    if [[ "$cname" == "$container_name" ]]; then
      echo "$user"
      return 0
    fi
  done < <(discover)
  echo "node"
}

# --- Build the exec command array for container entry ---
build_exec_cmd() {
  local container_name="$1"
  local user="$2"
  local workspace="${3:-}"

  # Build the podman/docker exec command
  local -n _cmd=$4
  _cmd=(
    "$RUNTIME" exec -it
    --user "$user"
  )
  if [[ -n "$workspace" ]]; then
    _cmd+=(--workdir "$workspace")
  fi
  _cmd+=("$container_name" /bin/bash -l)
}

# --- Connect to a project via tmux ---
do_connect() {
  local project="$1"
  local container_name="$2"
  local workspace="${3:-}"
  local user
  user=$(resolve_user_for_container "$container_name")

  if [[ "$DRY_RUN" == "true" ]]; then
    echo "# Container exec command:"
    echo "$RUNTIME exec -it --user $user --workdir ${workspace:-(default)} $container_name /bin/bash -l"
    echo ""
    echo "# tmux session commands:"
    echo "tmux new-session -d -s \"$project\" -e LACE_CONTAINER=$container_name <exec_command>"
    echo "tmux set-option -t \"$project\" remain-on-exit failed"
    echo "tmux select-pane -t \"$project\" -T \"shell\""
    echo "tmux set-option -t \"$project\" @lace_container \"$container_name\""
    echo "tmux set-option -t \"$project\" @lace_user \"$user\""
    echo "tmux set-option -t \"$project\" @lace_workspace \"$workspace\""
    echo "tmux attach-session -t \"=$project\"  # or switch-client if inside tmux"
    exit 0
  fi

  # Build exec command (reused across panes)
  local exec_cmd=()
  build_exec_cmd "$container_name" "$user" "$workspace" exec_cmd

  # Check for existing session.
  # Verify the session's @lace_container matches to avoid name collisions.
  # Then check pane health: reattach if all alive, respawn dead panes in place.
  # Never kill lace sessions: respawn-in-place avoids tmux-continuum/resurrect
  # conflicts and preserves session-level options (@lace_container etc.).
  if tmux has-session -t "=$project" 2>/dev/null; then
    local existing_container
    existing_container=$(tmux show-option -t "$project" -qv @lace_container 2>/dev/null)
    if [ "$existing_container" = "$container_name" ] || [ -z "$existing_container" ]; then
      local total_panes alive_panes
      total_panes=$(tmux list-panes -t "=$project" -F '#{pane_dead}' | wc -l)
      alive_panes=$(tmux list-panes -t "=$project" -F '#{pane_dead}' | grep -c '^0$' || true)

      if [ "$total_panes" -gt 0 ] && [ "$alive_panes" -eq "$total_panes" ]; then
        # All panes alive: reattach
        info "attaching to existing session: $project"
        if [ -n "$TMUX" ]; then
          tmux switch-client -t "=$project"
        else
          exec tmux attach-session -t "=$project"
        fi
        return 0
      fi

      # Some or all panes are dead: respawn them in place.
      local dead_count=$((total_panes - alive_panes))
      info "respawning $dead_count dead pane(s) in session $project"

      # Update session options in case container or user changed
      tmux set-option -t "$project" @lace_container "$container_name"
      tmux set-option -t "$project" @lace_user "$user"
      if [[ -n "$workspace" ]]; then
        tmux set-option -t "$project" @lace_workspace "$workspace"
      fi

      # Respawn each dead pane with the current exec command
      local dead_panes
      dead_panes=$(tmux list-panes -t "=$project" -F '#{pane_id} #{pane_dead}' \
                   | awk '$2 == 1 {print $1}')
      for pane_id in $dead_panes; do
          tmux respawn-pane -t "$pane_id" "${exec_cmd[@]}"
          # Set pane-level options for lace-split context detection
          tmux set-option -p -t "$pane_id" @lace_container "$container_name"
          tmux set-option -p -t "$pane_id" @lace_user "$user"
          if [[ -n "$workspace" ]]; then
            tmux set-option -p -t "$pane_id" @lace_workspace "$workspace"
          fi
      done

      if [ -n "$TMUX" ]; then
        tmux switch-client -t "=$project"
      else
        exec tmux attach-session -t "=$project"
      fi
      return 0
    else
      # Container name mismatch: disambiguate session name with container ID prefix
      local short_id
      short_id=$("$RUNTIME" inspect "$container_name" --format '{{.Id}}' 2>/dev/null | head -c 8 || echo "unknown")
      project="${project}-${short_id}"
      info "session name conflict, using: $project"
    fi
  fi

  # Create new session with exec pane
  tmux new-session -d -s "$project" -e "LACE_CONTAINER=$container_name" "${exec_cmd[@]}"
  tmux set-option -t "$project" remain-on-exit failed
  tmux select-pane -t "$project" -T "shell"

  # Store container connection details as session-level user options for split automation.
  tmux set-option -t "$project" @lace_container "$container_name"
  tmux set-option -t "$project" @lace_user "$user"
  if [[ -n "$workspace" ]]; then
    tmux set-option -t "$project" @lace_workspace "$workspace"
  fi

  # Also set pane-level options on the initial pane for lace-split context detection.
  local initial_pane
  initial_pane=$(tmux list-panes -t "=$project" -F '#{pane_id}' | head -1)
  tmux set-option -p -t "$initial_pane" @lace_container "$container_name"
  tmux set-option -p -t "$initial_pane" @lace_user "$user"
  if [[ -n "$workspace" ]]; then
    tmux set-option -p -t "$initial_pane" @lace_workspace "$workspace"
  fi

  if [ -n "$TMUX" ]; then
    tmux switch-client -t "=$project"
  else
    exec tmux attach-session -t "=$project"
  fi
}

# --- Connect current pane to a project (--pane mode) ---
do_connect_pane() {
  local project="$1"
  local container_name="$2"
  local workspace="${3:-}"
  local user
  user=$(resolve_user_for_container "$container_name")

  # Build exec command (same construction as do_connect)
  local exec_cmd=()
  build_exec_cmd "$container_name" "$user" "$workspace" exec_cmd

  if [[ "$DRY_RUN" == "true" ]]; then
    echo "# --pane mode: respawn current pane with container exec"
    echo "tmux respawn-pane -k -t \"$TMUX_PANE\" ${exec_cmd[*]}"
    echo ""
    echo "# Session-level options (set-if-absent):"
    echo "tmux set-option @lace_container \"$container_name\""
    echo "tmux set-option @lace_user \"$user\""
    if [[ -n "$workspace" ]]; then
      echo "tmux set-option @lace_workspace \"$workspace\""
    fi
    echo ""
    echo "# Pane title:"
    echo "tmux select-pane -t \"$TMUX_PANE\" -T \"$project\""
    exit 0
  fi

  # Respawn the current pane with the exec command
  tmux respawn-pane -k -t "$TMUX_PANE" "${exec_cmd[@]}"

  # Set pane-level options for lace-split context detection.
  # lace-split checks pane-level @lace_container to decide
  # whether to container-split or local-split.
  tmux set-option -p -t "$TMUX_PANE" @lace_container "$container_name"
  tmux set-option -p -t "$TMUX_PANE" @lace_user "$user"
  if [[ -n "$workspace" ]]; then
    tmux set-option -p -t "$TMUX_PANE" @lace_workspace "$workspace"
  fi

  # Set session-level options if not already set (status queries)
  local existing_container
  existing_container=$(tmux show-option -qv @lace_container 2>/dev/null)
  if [[ -z "$existing_container" ]]; then
    tmux set-option @lace_container "$container_name"
    tmux set-option @lace_user "$user"
    if [[ -n "$workspace" ]]; then
      tmux set-option @lace_workspace "$workspace"
    fi
  elif [[ "$existing_container" != "$container_name" ]]; then
    info "warning: session @lace_container ($existing_container) differs from pane target ($container_name)"
  fi

  # Update pane title
  tmux select-pane -t "$TMUX_PANE" -T "$project"
}

# --- Execute action ---
case "$ACTION" in
  list)
    discover | cut -d: -f1
    exit 0
    ;;
  status)
    projects_output=$(discover)
    if [[ -z "$projects_output" ]]; then
      info "no running devcontainers found"
      exit 0
    fi
    printf "%-20s %-20s %-10s %-30s %s\n" "PROJECT" "CONTAINER" "USER" "PATH" "WORKSPACE"
    printf "%-20s %-20s %-10s %-30s %s\n" "-------" "---------" "----" "----" "---------"
    echo "$projects_output" | while IFS=: read -r name cname user path ws; do
      printf "%-20s %-20s %-10s %-30s %s\n" "$name" "$cname" "$user" "$path" "$ws"
    done
    exit 0
    ;;
  help)
    cat <<'EOF'
lace-into -- Connect to a lace devcontainer via tmux

Usage:
  lace-into                    Interactive picker (fzf or bash select)
  lace-into <project>          Connect to named project
  lace-into --pane <project>   Connect current tmux pane to named project
  lace-into --pane             Interactive picker, connect current pane
  lace-into --start <project>  Start a stopped container, then connect
  lace-into --start            Pick from stopped containers to start
  lace-into --start --rebuild <project>  Start with full rebuild (recreate container)
  lace-into --list             List running project names
  lace-into --status           Show running projects with containers and paths
  lace-into --dry-run <proj>   Print the connect command without executing
  lace-into --help             Show this help

Projects are discovered via the container runtime (containers with
devcontainer.local_folder label). Discovery is performed by lace-discover.

Connection creates a tmux session with a container exec pane:
  tmux new-session -d -s <project> podman exec -it --user <user> --workdir <ws> <container> /bin/bash -l
  tmux set-option -t <project> @lace_container <container_name>
  tmux attach-session -t =<project>

The --pane flag connects the current tmux pane to a container instead of
creating a dedicated session. Uses `tmux respawn-pane -k` to replace the
current pane's process with a container exec. Must be run from inside tmux.
Session-level @lace_container options are set if not already present,
enabling container-aware splits in the current session.

Session-level options @lace_container, @lace_user, and @lace_workspace
enable lace-split to open new splits into the same container, landing
in the workspace directory.

If a tmux session for the project already exists, lace-into attaches to
it (or switches to it, if already inside tmux).

The --start flag starts a stopped devcontainer before connecting. It uses
`lace up --workspace-folder <path>` for the full startup pipeline (config
generation, port allocation, lifecycle hooks). After startup, it re-discovers
the container and connects. If the project is already running, --start has
no effect (it just connects).

The --rebuild flag (used with --start) passes --rebuild to `lace up`, which
rebuilds the prebuild image and recreates the container from current config.
Use this after changing devcontainer.json to pick up runtime config changes
(environment variables, mounts, workspace folder, etc.).

The --dry-run flag prints the command(s) that would be executed without
actually running them. When combined with --start, it prints both the
lace up command and the tmux session creation commands.

Examples:
  lace-into lace                Connect to the lace devcontainer
  lace-into dotfiles            Connect to the dotfiles devcontainer
  lace-into                     Pick from running projects interactively
  lace-into --pane lace         Connect current pane to lace container
  lace-into --pane              Pick from running, connect current pane
  lace-into --pane --start lace Start lace if stopped, connect current pane
  lace-into --start lace        Start lace if stopped, then connect
  lace-into --start             Pick from stopped containers to start
  lace-into --start --dry-run lace  Show what --start would do
  lace-into --start --rebuild lace  Rebuild lace container from current config
  lace-into --list              Show names of running projects
  lace-into --status            Show a table of running projects
  lace-into --dry-run lace      Print the connect command for lace
EOF
    exit 0
    ;;
esac

# --- Connect to a specific project ---
if [[ -n "$PROJECT" ]]; then
  # Step 1: Check if already running
  container_name=""
  workspace=""

  while IFS=: read -r name cname user path ws; do
    if [[ "$name" == "$PROJECT" ]]; then
      container_name="$cname"
      workspace="$ws"
      break
    fi
  done < <(discover)

  if [[ -n "$container_name" ]]; then
    # Project is running -- connect directly (even if --start was given)
    if [[ "$START" == "true" ]]; then
      info "$PROJECT is already running"
    fi
    if [[ "$PANE_MODE" == "true" ]]; then
      do_connect_pane "$PROJECT" "$container_name" "$workspace"
    else
      do_connect "$PROJECT" "$container_name" "$workspace"
    fi
    exit 0  # reached only if exec in do_connect fails (e.g. dry-run already exits)
  fi

  # Step 2: If --start, look for stopped containers
  if [[ "$START" == "true" ]]; then
    workspace_path=""

    while IFS=$'\t' read -r sname spath; do
      if [[ "$sname" == "$PROJECT" ]]; then
        workspace_path="$spath"
        break
      fi
    done < <(discover_stopped)

    if [[ -n "$workspace_path" ]]; then
      start_and_connect "$PROJECT" "$workspace_path"
      exit 0
    else
      # Not found in stopped containers either
      err "project '$PROJECT' not found in running or stopped containers"
      stopped_output=$(discover_stopped)
      if [[ -n "$stopped_output" ]]; then
        err ""
        err "stopped containers:"
        echo "$stopped_output" | while IFS=$'\t' read -r sname spath; do
          echo "  $sname  ($spath)" >&2
        done
      else
        err "no stopped devcontainers found"
      fi
      err ""
      err "to create a new container: lace up --workspace-folder <path>"
      exit 1
    fi
  fi

  # Not running and --start not given
  err "project '$PROJECT' not found in running containers"
  running=$(discover | cut -d: -f1)
  if [[ -n "$running" ]]; then
    err ""
    err "running projects:"
    echo "$running" | sed 's/^/  /' >&2
  else
    err "no running devcontainers found"
  fi

  # Hint about --start if there are stopped containers
  stopped_output=$(discover_stopped)
  if [[ -n "$stopped_output" ]]; then
    found_in_stopped=false
    while IFS=$'\t' read -r sname spath; do
      if [[ "$sname" == "$PROJECT" ]]; then
        found_in_stopped=true
        break
      fi
    done <<< "$stopped_output"
    if [[ "$found_in_stopped" == "true" ]]; then
      err ""
      err "hint: '$PROJECT' is stopped. Use --start to start it:"
      err "  lace-into --start $PROJECT"
    fi
  fi
  exit 1
fi

# --- Interactive picker ---

if [[ "$START" == "true" ]]; then
  # --start without a project name: show picker of stopped containers
  # Include running containers too (they just get connected directly)
  mapfile -t RUNNING < <(discover)
  mapfile -t STOPPED < <(discover_stopped)

  # Build combined list: running projects marked as [running], stopped as [stopped]
  PICKER_ITEMS=()
  PICKER_DATA=()  # parallel array: "running\tname\tcontainer_name\tworkspace" or "stopped\tname\tpath"

  for proj in "${RUNNING[@]}"; do
    IFS=: read -r name cname user path ws <<< "$proj"
    PICKER_ITEMS+=("$name  [running]  $cname  $path")
    PICKER_DATA+=("running"$'\t'"$name"$'\t'"$cname"$'\t'"$ws")
  done

  for line in "${STOPPED[@]}"; do
    IFS=$'\t' read -r name path <<< "$line"
    # Skip if already in running list
    already_running=false
    for proj in "${RUNNING[@]}"; do
      rname="${proj%%:*}"
      if [[ "$rname" == "$name" ]]; then
        already_running=true
        break
      fi
    done
    if [[ "$already_running" == "false" ]]; then
      PICKER_ITEMS+=("$name  [stopped]  $path")
      PICKER_DATA+=("stopped"$'\t'"$name"$'\t'"$path"$'\t'"")
    fi
  done

  if [[ ${#PICKER_ITEMS[@]} -eq 0 ]]; then
    err "no running or stopped devcontainers found"
    err "to create a new container: lace up --workspace-folder <path>"
    exit 1
  fi

  if [[ ${#PICKER_ITEMS[@]} -eq 1 ]]; then
    IFS=$'\t' read -r kind name extra ws <<< "${PICKER_DATA[0]}"
    if [[ "$kind" == "running" ]]; then
      if [[ "$PANE_MODE" == "true" ]]; then
        do_connect_pane "$name" "$extra" "$ws"
      else
        do_connect "$name" "$extra" "$ws"
      fi
    else
      start_and_connect "$name" "$extra"
    fi
    exit 0
  fi

  # Multiple items -- show picker
  if command -v fzf &>/dev/null; then
    SELECTED=$(printf '%s\n' "${PICKER_ITEMS[@]}" | \
      fzf --prompt="lace-into --start> " --height=10 --reverse)
    [[ -z "$SELECTED" ]] && exit 0
    # Extract project name (first field)
    PICK_NAME=$(echo "$SELECTED" | awk '{print $1}')
  else
    PS3="lace-into --start> "
    mapfile -t DISPLAY_NAMES < <(printf '%s\n' "${PICKER_ITEMS[@]}")
    select PICK in "${DISPLAY_NAMES[@]}"; do
      [[ -n "$PICK" ]] && break
    done
    PICK_NAME=$(echo "$PICK" | awk '{print $1}')
  fi

  # Find matching entry in PICKER_DATA
  for i in "${!PICKER_ITEMS[@]}"; do
    item_name=$(echo "${PICKER_ITEMS[$i]}" | awk '{print $1}')
    if [[ "$item_name" == "$PICK_NAME" ]]; then
      IFS=$'\t' read -r kind name extra ws <<< "${PICKER_DATA[$i]}"
      if [[ "$kind" == "running" ]]; then
        if [[ "$PANE_MODE" == "true" ]]; then
          do_connect_pane "$name" "$extra" "$ws"
        else
          do_connect "$name" "$extra" "$ws"
        fi
      else
        start_and_connect "$name" "$extra"
      fi
      exit 0
    fi
  done

  err "internal error: selected project not found"
  exit 1
fi

# Normal interactive picker (no --start): running containers only
mapfile -t PROJECTS < <(discover)

if [[ ${#PROJECTS[@]} -eq 0 ]]; then
  err "no running devcontainers found"
  # Check if there are stopped containers and hint about --start
  stopped_output=$(discover_stopped)
  if [[ -n "$stopped_output" ]]; then
    err ""
    err "stopped containers available (use --start to start one):"
    echo "$stopped_output" | while IFS=$'\t' read -r sname spath; do
      echo "  $sname  ($spath)" >&2
    done
  else
    err "start a container with: lace up --workspace-folder <path>"
  fi
  exit 1
fi

if [[ ${#PROJECTS[@]} -eq 1 ]]; then
  IFS=: read -r name cname user path ws <<< "${PROJECTS[0]}"
  info "one project found: $name"
  if [[ "$PANE_MODE" == "true" ]]; then
    do_connect_pane "$name" "$cname" "$ws"
  else
    do_connect "$name" "$cname" "$ws"
  fi
  exit 0
fi

# Multiple projects -- show picker
if command -v fzf &>/dev/null; then
  SELECTED=$(printf '%s\n' "${PROJECTS[@]}" | \
    awk -F: '{printf "%-20s %s  %s\n", $1, $2, $4}' | \
    fzf --prompt="lace-into> " --height=10 --reverse)
  [[ -z "$SELECTED" ]] && exit 0
  PROJECT=$(echo "$SELECTED" | awk '{print $1}')
else
  PS3="lace-into> "
  mapfile -t NAMES < <(printf '%s\n' "${PROJECTS[@]}" | cut -d: -f1)
  select PROJECT in "${NAMES[@]}"; do
    [[ -n "$PROJECT" ]] && break
  done
fi

# Find container_name and workspace for selected project
for proj in "${PROJECTS[@]}"; do
  if [[ "${proj%%:*}" == "$PROJECT" ]]; then
    IFS=: read -r _ cname _ _ ws <<< "$proj"
    if [[ "$PANE_MODE" == "true" ]]; then
      do_connect_pane "$PROJECT" "$cname" "$ws"
    else
      do_connect "$PROJECT" "$cname" "$ws"
    fi
    exit 0
  fi
done

err "internal error: selected project not found"
exit 1
