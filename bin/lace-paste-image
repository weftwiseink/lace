#!/usr/bin/env nu

# Context-aware image paste: bridges clipboard images into containers via podman cp.
# Local panes: passes Ctrl+V through (app calls wl-paste directly).
# Container panes with lace metadata: saves image locally, copies to container, pastes path.

# Resolve container runtime: CONTAINER_RUNTIME env, then settings.json override, then auto-detect.
def resolve-runtime []: nothing -> string {
  let env_rt = ($env | get -o CONTAINER_RUNTIME | default "")
  if $env_rt in ["podman", "docker"] {
    return $env_rt
  }

  let settings_file = ($env.HOME | path join ".config/lace/settings.json")
  if ($settings_file | path exists) {
    let override_cmd = try {
      open $settings_file | get -o overridePodmanCommand | default ""
    } catch { "" }
    if ($override_cmd | is-not-empty) {
      return $override_cmd
    }
  }

  if (which podman | is-not-empty) { return "podman" }
  if (which docker | is-not-empty) { return "docker" }
  "MISSING_RUNTIME"
}

def main [pane_id: string] {
  let passthrough = { tmux send-keys -t $pane_id C-v }

  # Check clipboard for image MIME types (1s timeout guards against hung compositor)
  let mime_types = try { ^timeout 1s wl-paste -l | lines } catch { [] }
  let has_image = ($mime_types | any {|m| $m =~ '^image/(png|jpeg|gif|webp|bmp)$' })

  if not $has_image {
    do $passthrough
    return
  }

  # Detect whether pane is connected to a lace container via metadata
  let container = (lace-option $pane_id "@lace_container")

  if ($container | is-empty) {
    do $passthrough  # local pane: app handles wl-paste directly
    return
  }

  # Save clipboard image to local temp file
  let local_path = $"/tmp/lace-clipboard-($pane_id)-((date now | format date '%s')).png"
  try { ^wl-paste --type image/png out> $local_path } catch {
    rm -f $local_path
    do $passthrough
    return
  }

  if not ($local_path | path exists) or (ls $local_path | get size.0) == 0 {
    rm -f $local_path
    do $passthrough
    return
  }

  # Copy to container via podman/docker cp (replaces SCP-over-SSH)
  let runtime = (resolve-runtime)
  let remote_path = $"/tmp/(($local_path | path basename))"
  let cp_result = try {
    ^$runtime cp $local_path $"($container):($remote_path)"
    true
  } catch { false }

  rm -f $local_path

  if not $cp_result {
    do $passthrough
    return
  }

  # Paste remote path as literal text: Claude Code detects image paths automatically
  tmux send-keys -l -t $pane_id $remote_path
}

# Read a tmux option: pane-level first, session-level fallback
def lace-option [pane_id: string, option: string]: nothing -> string {
  let pane_val = try {
    tmux show-option -pqv -t $pane_id $option | str trim
  } catch { "" }
  if ($pane_val | is-not-empty) { return $pane_val }

  try { tmux show-option -qv -t $pane_id $option | str trim } catch { "" }
}
