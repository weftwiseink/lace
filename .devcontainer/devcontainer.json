{
  "name": "Lace Development (Worktrees)",
  "remoteUser": "node",
  // NOTE: docs/worktree_development.md for details.
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      // NOTE: Tied to project/bash-history declaration below
      "COMMAND_HISTORY_PATH": "/commandhistory",
      "USERNAME": "node"
    },
    "context": ".."
  },
  "customizations": {
    "lace": {
      // Workspace layout: auto-detect bare-repo worktree and generate
      // workspaceMount/workspaceFolder/postCreateCommand (safe.directory).
      // Without lace, set these manually (see comments at bottom of file).
      "workspace": {
        "layout": "bare-worktree",
        "mountTarget": "/workspaces/lace"
      },
      // Mount declarations: lace resolves host source paths from settings or defaults.
      // These are auto-injected into the mounts array during lace up.
      // Configure custom source paths in ~/.config/lace/settings.json
      "mounts": {
        "bash-history": {
          "target": "/commandhistory",
          "description": "Bash command history persistence"
        }
      },
      // Repo mounts: external repos cloned (or overridden via settings.json) and
      // bind-mounted into the container. Configure local overrides in
      // ~/.config/lace/settings.json under repoMounts.<repoId>.overrideMount.
      "repoMounts": {
        "github.com/weftwiseink/clauthier": {},
        "github.com/micimize/dotfiles": {
          "readonly": false
        }
      },
      "prebuildFeatures": {
        "ghcr.io/weftwiseink/devcontainer-features/lace-fundamentals:1": {},
        "ghcr.io/devcontainers/features/git:1": {
          "version": "latest"
        },
        "ghcr.io/devcontainers/features/rust:1": {
          "version": "latest",
          "profile": "default"
        },
        "./features/sprack": {}
      }
    }
  },
  "mounts": [
    // auto-injected from customizations.lace.mounts declarations
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "${lace.mount(claude-code/config).target}"
  },
  // tree-sitter-cli is installed by the neovim feature (via cargo + libclang-dev).
  // Lazy! sync downloads plugins and triggers treesitter parser compilation.
  // lace auto-prepends lace-fundamentals-init and appends safe.directory to this chain.
  "postCreateCommand": "nvim --headless '+Lazy! sync' +qa 2>&1 || echo 'WARN: nvim plugin sync failed (non-fatal)'"
  // workspaceMount, workspaceFolder, and postCreateCommand (safe.directory) are
  // auto-generated by customizations.lace.workspace above during `lace up`.
  // For contributors without lace, uncomment these lines:
  // "workspaceMount": "source=${localWorkspaceFolder}/..,target=/workspaces/lace,type=bind,consistency=delegated",
  // "workspaceFolder": "/workspaces/lace/main",
  // "postCreateCommand": "git config --global --add safe.directory '*'",
}
