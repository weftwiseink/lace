#!/bin/bash
# lace-split: Context-aware tmux split helper.
# If the active pane has lace metadata (@lace_container), the new split also
# exec's into the same container at the same workspace path.
# If the active pane is local, creates a local split preserving the current path.
#
# Detection:
#   Pane-level @lace_container option (set by lace-into and propagated by prior splits).
# Only pane-level metadata is checked (not session-level), so local panes
# in a lace session correctly get local splits.
#
# Usage: lace-split [-h|-v] [-U] [-t pane_id]
#   -h          Horizontal split (split-window -h, default)
#   -v          Vertical split (split-window -v)
#   -U          Swap pane up after split (for left/up splits)
#   -t pane_id  Target pane for metadata lookup and split (default: current pane)
#
# Called from tmux keybindings. Not intended for direct user invocation.
# Keybindings should pass #{pane_id} via -t for reliable pane targeting:
#   run-shell 'lace-split -h -t "#{pane_id}"'

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR points to the real script directory,
# not the symlink directory (e.g. ~/.local/bin). This ensures lace-lib.sh
# is found when lace-split is invoked via symlink from tmux run-shell.
_source="${BASH_SOURCE[0]}"
while [ -L "$_source" ]; do
  _dir="$(cd "$(dirname "$_source")" && pwd)"
  _source="$(readlink "$_source")"
  [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"
unset _source _dir
# shellcheck source=lace-lib.sh
. "$SCRIPT_DIR/lace-lib.sh"

DIRECTION="-h"
SWAP=""
TARGET=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h) DIRECTION="-h"; shift ;;
    -v) DIRECTION="-v"; shift ;;
    -U) SWAP="yes"; shift ;;
    -t) TARGET="$2"; shift 2 ;;
    *) shift ;;
  esac
done

# Build target args for tmux commands. When -t is provided, all tmux queries
# and split-window target that specific pane. Without -t, tmux uses the
# "current" pane from the run-shell context (correct in keybinding context,
# unreliable when called externally).
TARGET_ARGS=()
if [ -n "$TARGET" ]; then
  TARGET_ARGS=(-t "$TARGET")
fi

# Check pane-level lace metadata.
# Only pane-level: session-level @lace_container exists but applies to all panes
# in the session, including local ones. Pane-level is set by lace-into on
# the initial pane and propagated by lace-split to each new container split.
container=$(tmux show-option -pqv "${TARGET_ARGS[@]}" @lace_container 2>/dev/null)

if [ -z "$container" ]; then
  # Local pane: local split preserving current directory
  tmux split-window "$DIRECTION" "${TARGET_ARGS[@]}" -c "#{pane_current_path}"
  if [ -n "$SWAP" ]; then
    tmux swap-pane -U
  fi
  exit 0
fi

# Container pane: read remaining lace connection details
user=$(tmux show-option -pqv "${TARGET_ARGS[@]}" @lace_user 2>/dev/null)
ws=$(tmux show-option -pqv "${TARGET_ARGS[@]}" @lace_workspace 2>/dev/null)

# Build exec command for the new pane
exec_args=("$RUNTIME" exec -it --user "${user:-node}")
if [ -n "$ws" ]; then
  exec_args+=(--workdir "$ws")
fi
exec_args+=("$container" /bin/bash -l)

new_pane=$(tmux split-window "$DIRECTION" "${TARGET_ARGS[@]}" -PF '#{pane_id}' "${exec_args[@]}")

# Propagate lace options to the new pane for future splits
tmux set-option -p -t "$new_pane" @lace_container "$container"
[ -n "$user" ] && tmux set-option -p -t "$new_pane" @lace_user "$user"
[ -n "$ws" ] && tmux set-option -p -t "$new_pane" @lace_workspace "$ws"

if [ -n "$SWAP" ]; then
  tmux swap-pane -U
fi
