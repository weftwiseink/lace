#!/bin/bash
# lace-split: Context-aware tmux split helper.
# If the active pane has lace metadata (@lace_container), the new split also
# exec's into the same container at the same workspace path.
# If the active pane is local, creates a local split preserving the current path.
#
# Detection:
#   Pane-level @lace_container option (set by lace-into and propagated by prior splits).
# Only pane-level metadata is checked (not session-level), so local panes
# in a lace session correctly get local splits.
#
# Usage: lace-split [-h|-v] [-U]
#   -h   Horizontal split (split-window -h, default)
#   -v   Vertical split (split-window -v)
#   -U   Swap pane up after split (for left/up splits)
#
# Called from tmux keybindings. Not intended for direct user invocation.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lace-lib.sh
. "$SCRIPT_DIR/lace-lib.sh"

DIRECTION="-h"
SWAP=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h) DIRECTION="-h"; shift ;;
    -v) DIRECTION="-v"; shift ;;
    -U) SWAP="yes"; shift ;;
    *) shift ;;
  esac
done

# Check pane-level lace metadata.
# Only pane-level: session-level @lace_container exists but applies to all panes
# in the session, including local ones. Pane-level is set by lace-into on
# the initial pane and propagated by lace-split to each new container split.
container=$(tmux show-option -pqv @lace_container 2>/dev/null)

if [ -z "$container" ]; then
  # Local pane: local split preserving current directory
  tmux split-window "$DIRECTION" -c "#{pane_current_path}"
  if [ -n "$SWAP" ]; then
    tmux swap-pane -U
  fi
  exit 0
fi

# Container pane: read remaining lace connection details
user=$(tmux show-option -pqv @lace_user 2>/dev/null)
ws=$(tmux show-option -pqv @lace_workspace 2>/dev/null)

# Build exec command for the new pane
exec_args=("$RUNTIME" exec -it --user "${user:-node}")
if [ -n "$ws" ]; then
  exec_args+=(--workdir "$ws")
fi
exec_args+=("$container" /bin/bash -l)

new_pane=$(tmux split-window "$DIRECTION" -PF '#{pane_id}' "${exec_args[@]}")

# Propagate lace options to the new pane for future splits
tmux set-option -p -t "$new_pane" @lace_container "$container"
[ -n "$user" ] && tmux set-option -p -t "$new_pane" @lace_user "$user"
[ -n "$ws" ] && tmux set-option -p -t "$new_pane" @lace_workspace "$ws"

if [ -n "$SWAP" ]; then
  tmux swap-pane -U
fi
