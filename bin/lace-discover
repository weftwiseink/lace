#!/bin/bash
# Discover running lace devcontainers via container labels.
#
# Usage:
#   lace-discover           # Output: name:container_name:user:path:workspace per line
#   lace-discover --json    # Output: JSON array of project objects
#
# This script queries the container runtime for running devcontainers that have
# the devcontainer.local_folder label (set by devcontainer CLI).
#
# Output format (default):
#   project-name:container-name:node:/path/to/project:/container/workspace
#
# JSON format:
#   [{"name":"project-name","container_name":"container-name","container_id":"abc123","user":"node","path":"/path/to/project","workspace":"/container/workspace"}]

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR points to the real script directory.
_source="${BASH_SOURCE[0]}"
while [ -L "$_source" ]; do
  _dir="$(cd "$(dirname "$_source")" && pwd)"
  _source="$(readlink "$_source")"
  [[ "$_source" != /* ]] && _source="$_dir/$_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_source")" && pwd)"
unset _source _dir
# shellcheck source=lace-lib.sh
. "$SCRIPT_DIR/lace-lib.sh"

# Parse arguments
OUTPUT_FORMAT="text"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      OUTPUT_FORMAT="json"
      shift
      ;;
    -h|--help)
      head -19 "${BASH_SOURCE[0]}" | tail -n +2 | sed 's/^# \?//'
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      echo "Usage: lace-discover [--json] [--help]" >&2
      exit 1
      ;;
  esac
done

# Check if container runtime daemon is running
if ! "$RUNTIME" info &>/dev/null 2>&1; then
  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    echo "[]"
  fi
  exit 0
fi

# Get all devcontainers with their local folders
# Format: container_id \t local_folder \t project_name
discover_raw() {
  "$RUNTIME" ps --filter "label=devcontainer.local_folder" \
    --format '{{.ID}}\t{{.Label "devcontainer.local_folder"}}\t{{.Label "lace.project_name"}}' 2>/dev/null || true
}

# Parse the raw output and extract projects
discover_projects() {
  while IFS=$'\t' read -r container_id local_folder project_name; do
    # Skip empty lines
    [[ -z "$container_id" ]] && continue

    # Use label-based name if available, fall back to basename for pre-label containers
    name="${project_name:-$(basename "$local_folder")}"

    # Get the sanitized container name from inspect (matches sanitizeContainerName() in TypeScript).
    # podman inspect returns the name with a leading "/" which we strip.
    container_name=$("$RUNTIME" inspect "$container_id" --format '{{.Name}}' 2>/dev/null | sed 's|^/||' || true)
    [[ -z "$container_name" ]] && continue

    # Get container user from devcontainer metadata remoteUser (most reliable),
    # falling back to Config.User, then to "node" default.
    # Config.User is the container's default process user, which may be "root"
    # even when the accessible user is different (e.g., "vscode").
    #
    # NOTE: This implements the same resolution semantics as extractRemoteUser()
    # in packages/lace/src/lib/devcontainer.ts, which resolves the remote user
    # at config-generation time from source files. This operates at runtime from
    # container metadata. Both follow the same three-tier resolution:
    # explicit remoteUser > inspected/parsed user > default.
    # The defaults differ: this defaults to "node" (lace convention); TypeScript
    # defaults to "root" (devcontainer spec). See the proposal at
    # cdocs/proposals/2026-03-07-remote-user-resolution-in-mount-targets.md.
    user=""
    metadata=$("$RUNTIME" inspect "$container_id" --format '{{index .Config.Labels "devcontainer.metadata"}}' 2>/dev/null || echo "")
    if [[ -n "$metadata" ]]; then
      # Extract remoteUser from the JSON metadata array
      remote_user=$(echo "$metadata" | grep -oP '"remoteUser"\s*:\s*"\K[^"]+' | head -1 || true)
      [[ -n "$remote_user" ]] && user="$remote_user"
    fi
    # Fallback: Config.User
    if [[ -z "$user" ]]; then
      user=$("$RUNTIME" inspect "$container_id" --format '{{.Config.User}}' 2>/dev/null || echo "")
      # Default to "node" if user is empty (root or unset)
      [[ -z "$user" || "$user" == "root" ]] && user="node"
    fi

    # Get container workspace folder from CONTAINER_WORKSPACE_FOLDER env var.
    # This is set by lace up from the resolved workspaceFolder in devcontainer config.
    # Falls back to empty string if not set (pre-lace containers).
    workspace=""
    workspace=$("$RUNTIME" inspect "$container_id" \
      --format '{{range .Config.Env}}{{println .}}{{end}}' 2>/dev/null \
      | grep '^CONTAINER_WORKSPACE_FOLDER=' | head -1 | cut -d= -f2- || true)

    if [[ "$OUTPUT_FORMAT" == "json" ]]; then
      # Output JSON object (without trailing comma - handled by caller)
      printf '{"name":"%s","container_name":"%s","container_id":"%s","user":"%s","path":"%s","workspace":"%s"}\n' \
        "$name" "$container_name" "$container_id" "$user" "$local_folder" "$workspace"
    else
      # Output text format: name:container_name:user:path:workspace
      echo "$name:$container_name:$user:$local_folder:$workspace"
    fi
  done < <(discover_raw)
}

if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  # Collect all JSON objects, then wrap in array
  mapfile -t projects < <(discover_projects)
  if [[ ${#projects[@]} -eq 0 ]]; then
    echo "[]"
  else
    # Join with commas
    printf '['
    first=true
    for proj in "${projects[@]}"; do
      if [[ "$first" == "true" ]]; then
        first=false
      else
        printf ','
      fi
      printf '%s' "$proj"
    done
    printf ']\n'
  fi
else
  discover_projects
fi
